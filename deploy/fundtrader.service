[Unit]
Description=FundTrader FastAPI Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/fundtrader/backend
Environment=API_HOST=0.0.0.0
Environment=API_PORT=8766
Environment=API_PREFIX=/fund/api
Environment=CACHE_DIR=/tmp/fundtrader_cache
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8766 --root-path /fund/api
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target