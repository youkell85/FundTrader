# FundTrader v2 后端环境变量模板
# 复制为 .env 并填入实际值: cp .env.example .env

# ── 数据源配置 ──
TICKFLOW_API_KEY=          # TickFlow API密钥
TICKFLOW_API_LEVEL=free    # free/starter/pro/expert

# Tushare（可选）
TUSHARE_TOKEN=             # Tushare Pro API Token

# iFinD MCP（可选）
IFIND_TOKEN=               # iFinD JWT Token
IFIND_USE_MCP=true         # true=使用MCP Server, false=使用REST API

# ── LLM 配置（可选，回测功能不依赖） ──
LLM_API_URL=https://api.minimaxi.com/v1/chat/completions
LLM_API_KEY=               # MiniMax Token Plan Key
LLM_MODEL=MiniMax-M2.7

# ── 服务配置 ──
API_HOST=0.0.0.0
API_PORT=8766
API_PREFIX=/fund/api

# ── 缓存配置 ──
CACHE_DIR=/tmp/fundtrader_cache
